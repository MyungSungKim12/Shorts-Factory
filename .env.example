# 복사해서 .env로 저장 후 값 채우기 (.env는 절대 커밋 금지)
# Gemini 무료 API (리서처/작가 에이전트용)
# 발급: https://aistudio.google.com/app/apikey (구글 계정만 있으면 무료)
GEMINI_API_KEY=여기에_발급받은_키_입력
GEMINI_MODEL=gemini-flash-latest

# 이미지/영상 관련
PEXELS_API_KEY=여기에_발급받은_키_입력
PIXABAY_API_KEY=
FFMPEG_PATH=D:\ms\ffmpeg-8.1.2-essentials_build\bin\ffmpeg.exe

# 경로/권한 설정
DATA_DIR=./data
UPLOAD_PRIVACY=public
DAILY_UPLOAD_LIMIT=6

# 나레이션 배속 (1.0=원속, 1.2=20% 빠르게)
TTS_SPEED=1.2

# 자막 폰트 (Windows: Malgun Gothic / 리눅스 서버: NanumGothic)
SUBTITLE_FONT=Malgun Gothic

# BGM 볼륨 (assets/bgm/에 mp3를 넣으면 자동으로 깔림, 0.1~0.2 권장)
BGM_VOLUME=0.12
